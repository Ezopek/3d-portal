# Application
PORTAL_VERSION=0.1.0
ENVIRONMENT=production

# API
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-32-bytes-hex
# TOTP_FERNET_KEY — generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_FERNET_KEY=
# COOKIE_SECURE=true   # Set to false only for plain-HTTP local dev
COOKIE_SECURE=true

# 2FA enforcement (Story 7.4, Decision F).
# Comma-separated list of UserRole names whose users MUST enroll 2FA on
# next login. Valid roles: admin, member. The `agent` role is FORBIDDEN —
# forcing 2FA on the service account would brick AI ingestion; the app
# fails fast on startup if `agent` appears in this list. Default empty
# (no enforcement) keeps Initiative 5 in voluntary-enrollment mode until
# operator explicitly opts in.
# ENFORCE_2FA_FOR_ROLES=

# Rate-limiting (Story 6.6, architecture.md § Initiative 5 Decision G).
# Sliding-window thresholds per IP per scope; defaults shown — uncomment to override.
# RATELIMIT_LOGIN_WINDOW_SECONDS=60
# RATELIMIT_LOGIN_THRESHOLD=5
# RATELIMIT_REFRESH_WINDOW_SECONDS=60
# RATELIMIT_REFRESH_THRESHOLD=10
# RATELIMIT_REGISTER_WINDOW_SECONDS=60
# RATELIMIT_REGISTER_THRESHOLD=3
# RATELIMIT_SHARE_WINDOW_SECONDS=86400
# RATELIMIT_SHARE_THRESHOLD=20
# RATELIMIT_SHARE_SOFT_ALERT_THRESHOLD=10
# Story 19.1 / Decision Q — anonymous /api/share/{token}/* DDoS cap.
# RATELIMIT_SHARE_ANON_WINDOW_SECONDS=60
# RATELIMIT_SHARE_ANON_THRESHOLD=60
# RATELIMIT_SHARE_ANON_SOFT_ALERT_THRESHOLD=30
# Story 23.3 / Decision Y — per-token (IP-independent) /api/share/{token}/* cap.
# Layered on top of the per-(token, IP) cap above; bounds total req/token
# regardless of source IP (botnet defeats per-IP cap, per-token catches it).
# RATELIMIT_SHARE_PER_TOKEN_WINDOW_SECONDS=60
# RATELIMIT_SHARE_PER_TOKEN_THRESHOLD=60
# RATELIMIT_SHARE_PER_TOKEN_SOFT_ALERT_THRESHOLD=  # optional, default unset
# Password-reset link TTL (Story 8.5; admin-issued reset link consume TTL).
# PASSWORD_RESET_TTL_SECONDS=3600

# Initiative 19 Story 31.1 (Decision AE) — Spoolman read-only inventory mirror.
# Primary topology P4b: portal-api joins the same docker network as Spoolman
# and resolves http://spoolman:8000. Fallback P4a (transitional, one-line):
# set SPOOLMAN_URL=http://localhost:7912 if the configs-side compose PR
# attaching Spoolman to portal-network has not yet shipped. The configs-side
# Spoolman compose MUST bind to a non-routable host interface (NOT 0.0.0.0
# exposed via router) — verified separately per OD8.
# SPOOLMAN_URL=http://spoolman:8000
# SPOOLMAN_AUTH_TOKEN=

# Initiative 20 Story 32.1 (Decision AH/AI/AJ) — Orca profile resolver.
# ORCA_VERSION is folded into bundle_hash so an Orca upgrade is a clean
# bulk-invalidation event (Decision AJ). Pin it to the verified Linux AppImage
# build the slicer-worker container ships (Story 32.2).
# ORCA_VERSION=2.3.2
# Vendored Orca system-profile tree + user partials (exported artifacts read at
# resolve time) and the append-only bundle/snapshot store ROOT, both under the
# portal-content volume. Defaults are container-internal; override only if the
# layout differs. SLICER_BUNDLE_STORE_DIR is the store ROOT — the resolver adds the
# internal bundles/ and snapshots/ children, so it is /data/content/slicer (NOT
# /data/content/slicer/bundles, which would nest to .../bundles/bundles/...).
# SLICER_VENDORED_PROFILES_DIR=/data/content/slicer/vendored
# SLICER_BUNDLE_STORE_DIR=/data/content/slicer
# SLICER_ESTIMATE_STORE_DIR is the append-only estimate cache ROOT (Story 32.3); like
# the bundle store it is the ROOT — EstimateStore adds the internal estimates/ child +
# the <stl_hash[:2]>/<stl_hash>/<bundle_hash>.json key layout, so it is /data/content/slicer
# (NOT /data/content/slicer/estimates, which would nest to .../estimates/estimates/...).
# SLICER_ESTIMATE_STORE_DIR=/data/content/slicer
# FENRIR_EXPORT_PATH is a BENCH-ONLY one-time export path used to snapshot the
# Orca system+user profile tree from the bench into the vendored artifact set.
# It is NOT read by production runtime (NFR20-CONTAINER-1) — the resolver only
# ever reads SLICER_VENDORED_PROFILES_DIR. Leave unset in production.
# FENRIR_EXPORT_PATH=

# Initiative 20 Story 32.2 (Decision AI) — headless Orca slicer worker.
# These are the slicer-worker-RUNTIME knobs. Their production home is the
# configs-side slicer-worker container (AC-12), which shares the api image and so
# loads the same Settings; the api/arq-worker carry the same defaults purely to keep
# the settings-env-compose drift gate aligned (the value is inert there — only the
# slicer-worker actually spawns Orca). Defaults are container-internal; override only
# if the container layout differs.
#
# SLICER_ORCA_BIN — the Orca entrypoint (the --appimage-extract AppRun inside the
# slicer-worker container). The portal Settings field also accepts ORCA_BIN, which is
# the variable the configs-side slicer-worker recipe actually sets at runtime; keep
# SLICER_ORCA_BIN here so the name-based drift gate stays aligned.
# SLICER_ORCA_BIN=/opt/orca/orca
# SLICER_STL_CACHE_DIR — content-hash STL cache root on the portal-content volume;
# populated API-side at enqueue from the mirrored catalog copy (OD-8).
# SLICER_STL_CACHE_DIR=/data/content/slicer/stl-cache
# SLICER_MAX_CONCURRENCY — arq max_jobs cap (default 1; bounded so a minutes-long
# slice can't starve API/render workers on .190 — NFR20-RESOURCE-1). Lift to 2 only
# if .190 headroom allows.
# SLICER_MAX_CONCURRENCY=1
# SLICER_SLICE_TIMEOUT_SECONDS / SLICER_INFO_TIMEOUT_SECONDS — ARBITRARY conservative
# wall-time ceilings (slice / cheap --info pre-check) pending the configs-side R3
# slice-wall-time benchmark; NOT contractual constants (TB-016 lesson).
# SLICER_SLICE_TIMEOUT_SECONDS=900
# SLICER_INFO_TIMEOUT_SECONDS=60

# Volumes (host paths on .190)
CATALOG_HOST_DIR=/mnt/raid/3d-portal-data
RENDERS_HOST_DIR=/mnt/raid/3d-portal-renders
STATE_HOST_DIR=/mnt/raid/3d-portal-state
CACHE_HOST_DIR=/srv/portal/cache
CONTENT_HOST_DIR=/mnt/raid/3d-portal-content

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://192.168.2.190:4318
OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>

# Error tracking (GlitchTip / Sentry SDK)
# Both DSNs must be populated for end-to-end error capture:
#   - SENTRY_DSN      → injected into the API container at runtime
#   - VITE_SENTRY_DSN → baked into the web bundle at `pnpm build` time
# If either is empty the corresponding side silently no-ops — common cause
# of "errors are missing from GlitchTip".
SENTRY_DSN=https://<key>@glitchtip.ezop.ddns.net/<project_id>
VITE_SENTRY_DSN=https://<key>@glitchtip.ezop.ddns.net/<project_id>

# Sourcemap upload (deploy.sh skips silently without these)
GLITCHTIP_AUTH_TOKEN=<token-with-project:write+project:releases>
GLITCHTIP_ORG_SLUG=<org-slug>
GLITCHTIP_PROJECT_SLUG=3d-portal
