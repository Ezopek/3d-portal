# infra/.env.example — placeholders for keys consumed by infra/ tooling.
#
# Copy to infra/.env (gitignored) and fill values. Existing infra/.env
# entries for ADMIN_*, JWT_SECRET, OTEL_*, SENTRY_*, GLITCHTIP_*, etc. are
# NOT mirrored here yet — this file documents only the Story 10.1 cutover
# fixture additions until a broader brownfield-env audit pulls the rest
# in. Treat this as additive: presence of a key here means it is required
# by at least one shipped script; absence does not mean the key is unused.
#
# Story 10.1 — Cutover smoke fixtures (Decision J + NFR5-INT-1):
#   - AGENT_EMAIL/AGENT_PASSWORD are bootstrap-script-managed per
#     NFR5-INT-1; the value of AGENT_PASSWORD is rotated via DB-direct
#     surgery on the deploy target (Decision L §1741) and the new
#     plaintext is captured into infra/.env on the dev box. The admin
#     password-reset endpoint REJECTS targets with role=agent (see
#     apps/api/app/modules/auth/password_reset/admin_router.py:77).
#   - CUTOVER_TEST_MEMBER_EMAIL/PASSWORD seed a single-factor member
#     account via the E8 generate-invite + public register flow. Story
#     10.1 T4 does this once; the account persists across cutover.
#   - CUTOVER_TEST_MODEL_ID is the multipart-upload target for smoke
#     Scenario 2 (agent ingestion). Any existing catalog model works.
#   - CUTOVER_TEST_SHARE_TOKEN is rotated hourly by
#     cutover-share-token-refresh.sh and consumed by smoke Scenario 1
#     (share bypass).

# Agent service account (write access via /agent-runbook bypass)
AGENT_EMAIL=
AGENT_PASSWORD=

# Cutover test-member (seeded once via Story 10.1 T4)
CUTOVER_TEST_MEMBER_EMAIL=
CUTOVER_TEST_MEMBER_PASSWORD=

# Existing-catalog model used by smoke Scenario 2 (multipart STL upload)
CUTOVER_TEST_MODEL_ID=

# Initial share-token (rotated hourly by cutover-share-token-refresh.sh)
CUTOVER_TEST_SHARE_TOKEN=
