# Verify ritual — runtime tripwire (Story 3.1)
infra/.last-verify

# Visual regression
apps/web/tests/visual/test-results/
apps/web/tests/visual/__snapshots__/**/*.actual.png
apps/web/tests/visual/__snapshots__/**/*.diff.png

# Render artifacts (local fixtures only — production renders live on .190 volume)
workers/render/.local-renders/

# Implementation plans — kept local-only on purpose (may reference internal hosts/paths)
docs/plans/

# BMAD planning + implementation artifacts.
# Default-deny everything under _bmad-output/, then explicitly re-include the
# curated subset documented in AGENTS.md § BMAD artifact tracking. Scratch
# (story-automator runs, codex-review logs, raw audit dumps, code-reviews/)
# stays local because it can reference internal hosts/paths and bloats history.
_bmad-output/**

# Curated top-level docs
!_bmad-output/project-context.md
!_bmad-output/triage-backlog.md

# Planning artifacts — PRD, architecture, epics, sprint change proposals,
# product briefs, readiness reports, and the _runtime/ + archive/ history.
!_bmad-output/planning-artifacts/
!_bmad-output/planning-artifacts/**/
!_bmad-output/planning-artifacts/**/*.md
!_bmad-output/planning-artifacts/**/*.yaml

# Implementation artifacts — story specs, retros, sprint-status.
# audit-raw/, code-reviews/, codex-review dumps, and *.log dumps stay local.
!_bmad-output/implementation-artifacts/
!_bmad-output/implementation-artifacts/*.md
!_bmad-output/implementation-artifacts/sprint-status.yaml
_bmad-output/implementation-artifacts/codex-review-*.md
_bmad-output/implementation-artifacts/codex-review-*.log
_bmad-output/implementation-artifacts/code-reviews/
_bmad-output/implementation-artifacts/audit-raw/

# UX specs
!_bmad-output/ux/
!_bmad-output/ux/**/*.md

# Brainstorming sessions
!_bmad-output/brainstorming/
!_bmad-output/brainstorming/*.md

tmp/

# Orchestration logs (local-only operational state).
# Initiative 3 / Story E5.16 carves out review-prompts/ and bin/ — those are
# committed agent-tooling artifacts (architecture Decision J). Everything else
# under .codex/ stays local (session logs, scratch state).
.codex/*
!.codex/review-prompts/
!.codex/review-prompts/**
!.codex/bin/
!.codex/bin/**

# Brainstorming companion (local mockups + state)
.superpowers/

# Playwright MCP scratch screenshots from QA subagents (working dir leaks)
.playwright-mcp/
/*.png

# Claude scheduled task locks (session-only)
.claude/scheduled_tasks.lock
infra/.last-verify-runbook

# Deploy skip-gate state (range pointer; written on deploy-success only)
infra/.last-deploy-sha

# Hermes agent scratch — full-gate evidence logs + run prompts (local-only).
# `.hermes/run-logs/` is where agents tee `infra/scripts/check-all.sh` output
# for closeout evidence (see AGENTS.md § "Pre-push hook policy & gate evidence");
# the logs reference internal hosts/paths and must not enter history.
.hermes/
.claude/.story-automator-active
.bmad-loop/runs/
.bmad-loop/cache/
.bmad-loop/policy.toml

# Agent skill trees — tool-managed, not source of truth.
# Installed per-CLI by `bmad-method install` + `bmad-loop init` (regenerated on
# every run); committing them balloons history with churn that no reader outside
# the local harness needs. A fresh clone re-installs them, so they stay local.
.claude/skills/
.agent/skills/
.agents/skills/
.junie/skills/
